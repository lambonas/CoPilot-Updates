# ============================================================
# Local artifacts that should NOT be published to GitHub.
# The site itself is just index.html, styles.css, app.js,
# data/updates.json and .nojekyll — everything else is local.
# ============================================================

# --- Playwright / browser-automation test artifacts ---
.playwright-mcp/
playwright-report/
test-results/
.cache/

# --- Screenshots & images (none are part of the site) ---
# Ignore image files anywhere, but keep any that ever live under data/.
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.bmp
*.svg
*.pdf
!data/**

# --- OS junk ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- Logs & temp files ---
*.log
*.tmp
*.temp
*.bak
tmp/
temp/

# --- Node (only if you ever add tooling; site needs none) ---
node_modules/
npm-debug.log*
yarn-error.log*
.env
.env.*
